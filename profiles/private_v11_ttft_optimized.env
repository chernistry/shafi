# ==========================================================
# private_v11_ttft_optimized.env — TTFT < 1s target
# ==========================================================
# Base: private_v9_rerank12.env with aggressive TTFT cuts
# Goal: F=1.050 (+5.3pp vs current F=0.992)
# Risk: Slight quality loss acceptable if F gain > quality loss
# ==========================================================

# --- Embedding ---
EMBED_DIMENSIONS=1792
EMBED_MODEL=kanon-2-embedder

# --- Qdrant ---
QDRANT_COLLECTION=legal_chunks_private_1792
QDRANT_SHADOW_COLLECTION=legal_chunks_shadow_private_1792
QDRANT_PAGE_COLLECTION=legal_pages_private_1792
QDRANT_SUPPORT_FACT_COLLECTION=legal_support_facts_private_1792

# --- Qdrant: REDUCED prefetch for speed ---
QDRANT_PREFETCH_DENSE=60
QDRANT_PREFETCH_SPARSE=60

# --- Ingestion ---
INGEST_INGEST_VERSION=v2
INGEST_MANIFEST_DIR=platform_runs/private/manifests/private_1792

# --- Platform eval ---
EVAL_COLLECTION_PREFIX=legal_chunks_private_1792_platform

# --- Reranker: AGGRESSIVE speed cuts ---
RERANK_TOP_N=8
RERANK_RERANK_CANDIDATES=30

# --- LLM: FAST models, short outputs ---
LLM_SIMPLE_MODEL=gpt-4.1-mini
LLM_COMPLEX_MODEL=gpt-4.1-mini
LLM_STRICT_MODEL=gpt-4.1-mini
LLM_SUMMARY_MODEL=gpt-4.1-mini
LLM_FALLBACK_MODEL=gpt-4.1-mini
LLM_FREE_TEXT_SIMPLE_MODEL=gpt-4.1-mini
LLM_SIMPLE_MAX_TOKENS=200
LLM_COMPLEX_MAX_TOKENS=250
LLM_STRICT_MAX_TOKENS=100

# --- Pipeline: TIGHT context budgets ---
PIPELINE_MAX_ANSWER_WORDS=200
PIPELINE_STRICT_TYPES_CONTEXT_TOP_N=3
PIPELINE_NAME_CONTEXT_TOP_N=3
PIPELINE_BOOLEAN_CONTEXT_TOP_N=3

# --- Pipeline: features ---
PIPELINE_ENABLE_CROSS_REF_BOOSTS=true
PIPELINE_ENABLE_SEGMENT_RETRIEVAL=false
PIPELINE_ENABLE_DOC_DIVERSITY_EXPANSION=false
PIPELINE_PAGE_FIRST_ENABLED=false
PIPELINE_ENABLE_SHADOW_SEARCH_TEXT=false
PIPELINE_ENABLE_PARALLEL_ANCHOR_RETRIEVAL=false
PIPELINE_ENABLE_ENTITY_BOOSTS=false
PIPELINE_ENABLE_RAG_FUSION=false
PIPELINE_ENABLE_GROUNDING_SIDECAR=true
PIPELINE_ENABLE_TRAINED_PAGE_SCORER=true
PIPELINE_TRAINED_PAGE_SCORER_MODEL_PATH=models/page_scorer/private_v1/page_scorer.joblib
PIPELINE_ENABLE_CONFLICT_DETECTION=false
PIPELINE_ENABLE_MULTI_HOP=false
PIPELINE_ENABLE_ANSWER_VALIDATION=false
PIPELINE_ENABLE_ANSWER_CONSENSUS=false

# --- Judge ---
JUDGE_ENABLED=false

# --- Platform ---
EVAL_QUERY_CONCURRENCY=2

# --- Retrieval: tight ---
PIPELINE_STRICT_MULTI_REF_TOP_K_PER_REF=12
PIPELINE_BOOLEAN_RERANK_CANDIDATES_CAP=30
PIPELINE_STRICT_DOC_REF_TOP_K=16
PIPELINE_BOOLEAN_PREFETCH_DENSE=40
PIPELINE_BOOLEAN_PREFETCH_SPARSE=40
PIPELINE_STRICT_PREFETCH_DENSE=24
PIPELINE_STRICT_PREFETCH_SPARSE=24

# --- Free text: TIGHT ---
PIPELINE_CONTEXT_TOKEN_BUDGET_FREE_TEXT_COMPLEX=800
PIPELINE_CONTEXT_TOKEN_BUDGET_FREE_TEXT_SIMPLE=600

# --- Circuit breaker ---
LLM_CIRCUIT_FAILURE_THRESHOLD=10
LLM_CIRCUIT_RESET_TIMEOUT_S=10.0
EMBED_CIRCUIT_FAILURE_THRESHOLD=10
EMBED_CIRCUIT_RESET_TIMEOUT_S=10.0
RERANK_CIRCUIT_FAILURE_THRESHOLD=10
RERANK_CIRCUIT_RESET_TIMEOUT_S=10.0

# --- Warmup ---
APP_WARMUP_ENABLED=true
APP_WARMUP_EMBED=true
APP_WARMUP_LLM=true

# --- Boolean reranker ---
PIPELINE_RERANK_ENABLED_BOOLEAN=true

# --- Premise guard ---
PIPELINE_PREMISE_GUARD_TERMS=jury,miranda,parole,plea bargain
