# ==========================================================
# private_v8_isaacus_reranker.env — v7_1792_enhanced + Isaacus kanon-2-reranker
# ==========================================================
# A/B challenger: replace ZeroEntropy zerank-2 with Isaacus kanon-2-reranker.
# Isaacus is #1 on Legal RAG Bench — legal-specific training should improve
# precision on DIFC / case-law reranking.
#
# Usage:
#   cp profiles/private_v8_isaacus_reranker.env .env.local
#   # Also set in environment (NOT in profile — it's a secret):
#   export ISAACUS_API_KEY=<your key>
#   # Then restart server.
#
# Baseline: private_v7_1792_enhanced.env (G=0.4874 local / ~1.028 platform)
# Expected: +2-5pp G from legal-specific reranker
# Rollback: switch profile back to private_v7_1792_enhanced.env
# ==========================================================

# --- Embedding: 1792 dimensions (required — matches ingested Qdrant collections) ---
EMBED_DIMENSIONS=1792

# --- Qdrant: 1792-dim private collections ---
QDRANT_COLLECTION=legal_chunks_private_1792
QDRANT_SHADOW_COLLECTION=legal_chunks_shadow_private_1792
QDRANT_PAGE_COLLECTION=legal_pages_private_1792
QDRANT_SUPPORT_FACT_COLLECTION=legal_support_facts_private_1792

# --- Qdrant: expanded prefetch (v7 values) ---
QDRANT_PREFETCH_DENSE=120
QDRANT_PREFETCH_SPARSE=120

# --- Reranker: Isaacus kanon-2-reranker (ISAACUS_API_KEY must be set in environment) ---
RERANK_PROVIDER_MODE=isaacus
RERANK_TOP_N=8
RERANK_RERANK_CANDIDATES=120

# --- Ingestion ---
INGEST_INGEST_VERSION=v2
INGEST_MANIFEST_DIR=platform_runs/private/manifests/private_1792

# --- Platform eval ---
EVAL_COLLECTION_PREFIX=legal_chunks_private_1792_platform

# --- LLM token budgets ---
LLM_SIMPLE_MAX_TOKENS=300
LLM_COMPLEX_MAX_TOKENS=900
LLM_STRICT_MAX_TOKENS=150

# --- LLM models ---
LLM_SIMPLE_MODEL=gpt-4.1-mini
LLM_COMPLEX_MODEL=gpt-4.1
LLM_STRICT_MODEL=gpt-4.1-mini
LLM_SUMMARY_MODEL=gpt-4.1-mini
LLM_FALLBACK_MODEL=gpt-4.1-mini

# --- Pipeline: explicit reranker enable (guards against any inherited false) ---
PIPELINE_RERANKER_ENABLED=true

# --- Pipeline: v7-era context knobs (match v7_1792_enhanced) ---
PIPELINE_MAX_ANSWER_WORDS=350
PIPELINE_STRICT_TYPES_CONTEXT_TOP_N=5
PIPELINE_NAME_CONTEXT_TOP_N=5
PIPELINE_BOOLEAN_CONTEXT_TOP_N=5

# --- Pipeline: v7 retrieval enhancements ---
PIPELINE_ENABLE_CROSS_REF_BOOSTS=true
PIPELINE_ENABLE_SEGMENT_RETRIEVAL=true
PIPELINE_ENABLE_DOC_DIVERSITY_EXPANSION=true

# --- Pipeline: keep other experimental features disabled ---
PIPELINE_PAGE_FIRST_ENABLED=false
PIPELINE_ENABLE_SHADOW_SEARCH_TEXT=false
PIPELINE_ENABLE_PARALLEL_ANCHOR_RETRIEVAL=false
PIPELINE_ENABLE_ENTITY_BOOSTS=false
PIPELINE_ENABLE_RAG_FUSION=false
PIPELINE_ENABLE_GROUNDING_SIDECAR=true
PIPELINE_ENABLE_TRAINED_PAGE_SCORER=true
PIPELINE_TRAINED_PAGE_SCORER_MODEL_PATH=models/page_scorer/v8_temporal/page_scorer.joblib
PIPELINE_ENABLE_CONFLICT_DETECTION=false
PIPELINE_ENABLE_MULTI_HOP=false
PIPELINE_GROUNDING_RELEVANCE_VERIFIER_ENABLED=false
# Isaacus EQA: extract name/number/date answers without LLM (ISAACUS_API_KEY required)
PIPELINE_ENABLE_EXTRACTIVE_QA=true

# --- Pipeline: SISSY answer quality gate ---
PIPELINE_ENABLE_ANSWER_VALIDATION=true
PIPELINE_ENABLE_ANSWER_CONSENSUS=false

# --- Judge ---
JUDGE_ENABLED=false
JUDGE_SOURCES_MAX_PAGES=6

# --- Platform ---
EVAL_QUERY_CONCURRENCY=2
# Note: ISAACUS_API_KEY must be set as an environment variable, not in this file.
