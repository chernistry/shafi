# ==========================================================
# flashrank_gate_test.env — FlashRank 30Q gate test profile
# ==========================================================
# Usage (via start_flashrank_gate_server.sh):
#   Sources .env.local, then overlays this file.
#   Server runs on port 8001 to avoid disrupting V7 server.
#
# Purpose: 30Q gate test — FlashRank vs zerank-2 quality comparison.
# Pass condition: G_proxy >= 0.97 on 30Q stratified sample.
# TTFT target: < 1500ms avg (vs V7 baseline 2130ms)
# ==========================================================

# --- Reranker: switch to local FlashRank ---
RERANK_PROVIDER_MODE=flashrank
RERANK_LOCAL_MODEL_PATH=ms-marco-MiniLM-L-12-v2
RERANK_FLASHRANK_CACHE_DIR=/tmp/flashrank_models

# --- Port override ---
APP_PORT=8001

# --- Disable warmup to start faster ---
APP_WARMUP_ENABLED=false
APP_WARMUP_EMBED=false
APP_WARMUP_LLM=false
