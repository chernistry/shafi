# ==========================================================
# private_1792_regime.env — 1792-dim embedding profile for
# the private evaluation set
# ==========================================================
# Usage:
#   cp profiles/private_1792_regime.env .env.local
#   # OR for one-off:
#   ENV_FILE=profiles/private_1792_regime.env docker compose up
#
# Two-pipeline strategy
# ---------------------
# The private set is evaluated with TWO independent pipelines:
#
#   1. private_v6_regime.env  — the champion v6 config (1024-dim,
#      scored 0.742 on warmup).  Unchanged from submission v6.
#
#   2. private_1792_regime.env (THIS FILE) — identical v6 answering
#      logic but re-ingested with kanon-2-embedder at 1792 dimensions.
#      The hypothesis is that higher-dim embeddings improve recall
#      without changing any downstream pipeline behavior.
#
# After both pipelines produce answers, a replay/merge step
# (scripts/run_answer_stable_grounding_replay.py) selects the
# best answer per question.
#
# This profile is derived from private_v6_regime.env with only
# the embedding dimension and collection names changed.
# All post-v6 experimental features remain disabled.
# ==========================================================

# --- Embedding: 1792 dimensions (up from default 1024) ---
EMBED_DIMENSIONS=1792

# --- Qdrant: fresh collections for 1792-dim vectors ---
# These MUST differ from the v6 collections to avoid mixing
# 1024-dim and 1792-dim vectors in the same collection.
QDRANT_COLLECTION=legal_chunks_private_1792
QDRANT_SHADOW_COLLECTION=legal_chunks_shadow_private_1792
QDRANT_PAGE_COLLECTION=legal_pages_private_1792
QDRANT_SUPPORT_FACT_COLLECTION=legal_support_facts_private_1792

# --- Ingestion: isolated manifest directory ---
INGEST_INGEST_VERSION=v2
INGEST_MANIFEST_DIR=platform_runs/private/manifests/private_1792

# --- Platform eval: separate collection prefix ---
EVAL_COLLECTION_PREFIX=legal_chunks_private_1792_platform

# --- Reranker (v6 values) ---
RERANK_TOP_N=6
RERANK_RERANK_CANDIDATES=80

# --- LLM token budgets (v6 values) ---
LLM_SIMPLE_MAX_TOKENS=300
LLM_COMPLEX_MAX_TOKENS=900
LLM_STRICT_MAX_TOKENS=150

# --- LLM models (v6 values) ---
LLM_SIMPLE_MODEL=gpt-4.1-mini
LLM_COMPLEX_MODEL=gpt-4.1
LLM_STRICT_MODEL=gpt-4.1-mini
LLM_SUMMARY_MODEL=gpt-4.1-mini
LLM_FALLBACK_MODEL=gpt-4.1-mini

# --- Pipeline: v6-era knobs ---
PIPELINE_MAX_ANSWER_WORDS=350
PIPELINE_STRICT_TYPES_CONTEXT_TOP_N=3
PIPELINE_BOOLEAN_CONTEXT_TOP_N=2

# --- Pipeline: explicitly disable ALL post-v6 features ---
PIPELINE_PAGE_FIRST_ENABLED=false
PIPELINE_ENABLE_SHADOW_SEARCH_TEXT=false
PIPELINE_ENABLE_PARALLEL_ANCHOR_RETRIEVAL=false
PIPELINE_ENABLE_ENTITY_BOOSTS=false
PIPELINE_ENABLE_CROSS_REF_BOOSTS=false
PIPELINE_ENABLE_GROUNDING_SIDECAR=false
PIPELINE_ENABLE_TRAINED_PAGE_SCORER=false
PIPELINE_ENABLE_CONFLICT_DETECTION=false
PIPELINE_ENABLE_MULTI_HOP=false

# --- Judge ---
JUDGE_ENABLED=false
JUDGE_SOURCES_MAX_PAGES=6

# --- Platform ---
EVAL_QUERY_CONCURRENCY=2
