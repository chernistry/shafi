# Derived from main_baseline_20260319.env.
# Purpose: isolate the effect of moving kanon-2-embedder from 1024d to 1792d
# without mixing any other behavioral changes or contaminating champion
# collections.

INGEST_INGEST_VERSION=v2-local-bm25
INGEST_MANIFEST_DIR=platform_runs/warmup/manifests/kanon2_1792_ablation_20260319
PIPELINE_RERANK_ENABLED_BOOLEAN=true
PIPELINE_BOOLEAN_RERANK_CANDIDATES_CAP=20
PIPELINE_BOOLEAN_CONTEXT_TOP_N=6
PIPELINE_BOOLEAN_MULTI_REF_TOP_N=8
PIPELINE_STRICT_TYPES_CONTEXT_TOP_N=5
PIPELINE_CONTEXT_TOKEN_BUDGET_FREE_TEXT_SIMPLE=2400
PIPELINE_CONTEXT_TOKEN_BUDGET_FREE_TEXT_COMPLEX=3600
PIPELINE_MAX_ANSWER_WORDS=600

EMBED_DIMENSIONS=1792

EVAL_COLLECTION_PREFIX=legal_chunks_kanon2_1792_platform
QDRANT_COLLECTION=legal_chunks_kanon2_1792_20260319
