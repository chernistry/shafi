# =========================
# Competition Platform
# =========================
EVAL_API_KEY=
EVAL_BASE_URL=https://platform.agentic-challenge.ai/api/v1
EVAL_PHASE=warmup
EVAL_WORK_DIR=platform_runs
EVAL_DOCUMENTS_DIRNAME=documents
EVAL_QUESTIONS_FILENAME=questions.json
EVAL_SUBMISSION_FILENAME=submission.json
EVAL_CODE_ARCHIVE_FILENAME=code_archive.zip
EVAL_ARCHIVE_ALLOWLIST_PATH=src/rag_challenge/submission/archive_allowlist.json
EVAL_COLLECTION_PREFIX=legal_chunks_platform
EVAL_QUERY_CONCURRENCY=2
EVAL_POLL_INTERVAL_S=10.0
EVAL_POLL_TIMEOUT_S=1800.0
EVAL_ARCHITECTURE_SUMMARY=Async legal RAG with OCR-aware ingestion, clause-aware chunking, hybrid dense+BM25 retrieval in Qdrant, reranking, answer-type routing, and page-level grounded telemetry over phase-isolated corpora.

# =========================
# LLM (OpenAI-compatible)
# =========================
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
# Preferred generic key for any OpenAI-compatible provider
LLM_API_KEY=
# Backward-compat aliases (optional): OPENAI_API_KEY / OPENROUTER_API_KEY
LLM_OPENROUTER_REFERER=
LLM_OPENROUTER_TITLE=
ANTHROPIC_API_KEY=

# Per-role models
LLM_SIMPLE_MODEL=gpt-4.1-mini
LLM_COMPLEX_MODEL=gpt-4.1
LLM_STRICT_MODEL=gpt-4.1-mini
LLM_SUMMARY_MODEL=gpt-4.1-mini
LLM_FALLBACK_MODEL=gpt-4.1-mini

# LLM runtime knobs
LLM_SIMPLE_MAX_TOKENS=300
LLM_COMPLEX_MAX_TOKENS=900
LLM_STRICT_MAX_TOKENS=150
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_S=60.0
LLM_CONNECT_TIMEOUT_S=10.0
LLM_MAX_CONTEXT_TOKENS=2500
LLM_STREAM_INCLUDE_USAGE=true
LLM_HTTP2=true
LLM_MAX_CONNECTIONS=50
LLM_MAX_KEEPALIVE_CONNECTIONS=20
# OpenRouter routing hints (optional, OpenRouter base_url only)
LLM_OPENROUTER_PROVIDER_ORDER=
LLM_OPENROUTER_ALLOW_FALLBACKS=true
LLM_CIRCUIT_FAILURE_THRESHOLD=3
LLM_CIRCUIT_RESET_TIMEOUT_S=60.0
LLM_COMPLEX_MIN_LENGTH=150
LLM_COMPLEX_MIN_ENTITIES=2
# LLM_COMPLEX_KEYWORDS=compare,difference,exception,notwithstanding,distinguish,analyze,evaluate,contrast,jurisdiction,precedent

# =========================
# LLM-as-Judge (OpenAI-compatible, optional)
# =========================
JUDGE_ENABLED=false
JUDGE_BASE_URL=https://openrouter.ai/api/v1
JUDGE_API_KEY=
JUDGE_MODEL=google/gemini-2.5-flash-lite
JUDGE_TEMPERATURE=0.0
JUDGE_MAX_TOKENS=900
JUDGE_TIMEOUT_S=60.0
JUDGE_CONNECT_TIMEOUT_S=10.0
JUDGE_HTTP2=true
JUDGE_MAX_CONNECTIONS=20
JUDGE_MAX_KEEPALIVE_CONNECTIONS=10
JUDGE_CONCURRENCY=2
JUDGE_DOCS_DIR=dataset/dataset_documents
JUDGE_SOURCES_MAX_PAGES=6
JUDGE_SOURCES_MAX_CHARS_PER_PAGE=20000
JUDGE_SOURCES_MAX_CHARS_TOTAL=60000
# OpenRouter routing hints (optional, OpenRouter base_url only)
JUDGE_OPENROUTER_PROVIDER_ORDER=
JUDGE_OPENROUTER_ALLOW_FALLBACKS=true

# =========================
# Embedding
# =========================
ISAACUS_API_KEY=
EMBED_MODEL=kanon-2-embedder
EMBED_API_URL=https://api.isaacus.com/v1/embeddings
EMBED_DIMENSIONS=1024
EMBED_BATCH_SIZE=128
EMBED_CONCURRENCY=8
EMBED_TIMEOUT_S=30.0
EMBED_CONNECT_TIMEOUT_S=10.0
EMBED_RETRY_ATTEMPTS=6
EMBED_RETRY_BASE_DELAY_S=0.5
EMBED_RETRY_MAX_DELAY_S=16.0
EMBED_RETRY_JITTER_S=2.0
EMBED_CIRCUIT_FAILURE_THRESHOLD=3
EMBED_CIRCUIT_RESET_TIMEOUT_S=60.0

# =========================
# Reranker
# =========================
ZEROENTROPY_API_KEY=
COHERE_API_KEY=
RERANK_PRIMARY_MODEL=zerank-2
RERANK_PRIMARY_API_URL=https://api.zeroentropy.dev/v1/models/rerank
RERANK_PRIMARY_BATCH_SIZE=50
RERANK_PRIMARY_LATENCY_MODE=fast
RERANK_PRIMARY_TIMEOUT_S=30.0
RERANK_PRIMARY_MAX_CONNECTIONS=20
RERANK_PRIMARY_CONNECT_TIMEOUT_S=10.0
RERANK_FALLBACK_MODEL=rerank-v4.0-fast
RERANK_FALLBACK_TIMEOUT_S=30.0
RERANK_TOP_N=6
RERANK_RERANK_CANDIDATES=80
RERANK_RETRY_ATTEMPTS=4
RERANK_RETRY_BASE_DELAY_S=0.5
RERANK_RETRY_MAX_DELAY_S=8.0
RERANK_RETRY_JITTER_S=1.0
RERANK_CIRCUIT_FAILURE_THRESHOLD=3
RERANK_CIRCUIT_RESET_TIMEOUT_S=60.0

# =========================
# Qdrant
# =========================
# Cloud example:
# QDRANT_URL=https://<cluster-id>.<region>.aws.cloud.qdrant.io
# QDRANT_API_KEY=<qdrant_cloud_api_key>
# QDRANT_USE_CLOUD_INFERENCE=true
#
# Local example:
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_USE_CLOUD_INFERENCE=false
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=legal_chunks
QDRANT_POOL_SIZE=20
QDRANT_TIMEOUT_S=30.0
QDRANT_PREFETCH_DENSE=60
QDRANT_PREFETCH_SPARSE=60
QDRANT_USE_CLOUD_INFERENCE=false
QDRANT_ENABLE_SPARSE_BM25=true
QDRANT_SPARSE_MODEL=Qdrant/bm25
# Keep fastembed cache on a local writable path when running outside Docker.
QDRANT_FASTEMBED_CACHE_DIR=.cache/fastembed
QDRANT_SPARSE_THREADS=
QDRANT_CHECK_COMPATIBILITY=false
QDRANT_FUSION_METHOD=RRF
QDRANT_CIRCUIT_FAILURE_THRESHOLD=3
QDRANT_CIRCUIT_RESET_TIMEOUT_S=60.0

# =========================
# Pipeline
# =========================
PIPELINE_CONFIDENCE_THRESHOLD=0.3
PIPELINE_MAX_RETRIES=1
PIPELINE_RETRY_SPARSE_BIAS=90
PIPELINE_RETRY_DENSE_BIAS=40
PIPELINE_DOC_REF_CASE_LAW_FILTER=true
PIPELINE_DOC_REF_PREFETCH_DENSE=20
PIPELINE_DOC_REF_PREFETCH_SPARSE=120
PIPELINE_DOC_REF_SPARSE_ONLY=true
PIPELINE_DOC_REF_MULTI_RETRIEVE=true
PIPELINE_DOC_REF_MULTI_TOP_K_PER_REF=30
PIPELINE_PREMISE_GUARD_ENABLED=true
PIPELINE_PREMISE_GUARD_TERMS=jury,miranda,parole,plea bargain,plea
PIPELINE_RETRY_QUERY_MAX_ANCHORS=3
PIPELINE_MAX_ANSWER_WORDS=350
PIPELINE_RERANK_ENABLED_STRICT_TYPES=true
PIPELINE_RERANK_ENABLED_BOOLEAN=false
PIPELINE_RERANK_MAX_CANDIDATES_STRICT_TYPES=20
PIPELINE_BOOLEAN_RERANK_CANDIDATES_CAP=12
PIPELINE_STRICT_TYPES_CONTEXT_TOP_N=3
PIPELINE_STRICT_TYPES_EXTRACTION_ENABLED=true
PIPELINE_STRICT_TYPES_EXTRACTION_MAX_CHUNKS=4
PIPELINE_STRICT_TYPES_APPEND_CITATIONS=false
PIPELINE_STRICT_REPAIR_ENABLED=true
PIPELINE_BOOLEAN_CONTEXT_TOP_N=2
PIPELINE_BOOLEAN_MULTI_REF_TOP_N=3
PIPELINE_BOOLEAN_MAX_TOKENS=96
PIPELINE_BOOLEAN_PREFETCH_DENSE=40
PIPELINE_BOOLEAN_PREFETCH_SPARSE=40
PIPELINE_CONTEXT_TOKEN_BUDGET_BOOLEAN=900
PIPELINE_CONTEXT_TOKEN_BUDGET_STRICT=1100
PIPELINE_CONTEXT_TOKEN_BUDGET_FREE_TEXT_SIMPLE=1800
PIPELINE_CONTEXT_TOKEN_BUDGET_FREE_TEXT_COMPLEX=2400
PIPELINE_RERANK_SKIP_ON_SINGLE_DOC_REF=true
PIPELINE_RERANK_DOC_MAX_CHARS=1500
PIPELINE_USE_FAST_RERANKER_FOR_SIMPLE=false
PIPELINE_ENABLE_CONFLICT_DETECTION=false
PIPELINE_CONFLICT_DETECTION_ENABLED=false
PIPELINE_CONFLICT_MAX_CHUNKS=8
PIPELINE_ENABLE_MULTI_HOP=false
PIPELINE_DECOMPOSE_ENABLED=false
PIPELINE_MULTI_HOP_MAX_SUBQUERIES=3
PIPELINE_TTFT_EARLY_EMPTY_TOKEN_ENABLED=false

# =========================
# Ingestion
# =========================
INGEST_CHUNK_SIZE_TOKENS=450
INGEST_CHUNK_OVERLAP_TOKENS=45
INGEST_SAC_SUMMARY_MAX_TOKENS=150
INGEST_SAC_SUMMARY_MIN_TOKENS=80
INGEST_SAC_CONCURRENCY=4
INGEST_SAC_DOC_EXCERPT_CHARS=3000
INGEST_UPSERT_BATCH_SIZE=200
INGEST_INGEST_VERSION=v3_anchor_retrieval
INGEST_PARSER_PDF_TEXT_MIN_CHARS=400
INGEST_PARSER_PDF_TEXT_MIN_WORDS=80
INGEST_MANIFEST_HASH_CHUNK_SIZE_BYTES=1048576
INGEST_MANIFEST_DIR=
INGEST_MANIFEST_FILENAME=.rag_challenge_ingestion_manifest.json
INGEST_MANIFEST_SCHEMA_VERSION=1

# =========================
# Verifier
# =========================
VERIFY_ENABLED=true
VERIFY_MAX_TOKENS=500
VERIFY_TEMPERATURE=0.0

# =========================
# Application
# =========================
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=json
APP_ENVIRONMENT=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WARMUP_ENABLED=false
APP_WARMUP_EMBED=false
APP_WARMUP_LLM=false
APP_WARMUP_TIMEOUT_S=5.0
